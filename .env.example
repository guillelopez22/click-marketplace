# Copy this file to .env and fill in values.
# Start local DB: docker compose up -d
# Then run: pnpm prisma migrate dev && pnpm prisma db seed

# ─── Local development ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://click:click@localhost:5432/click_dev?schema=public"
DIRECT_URL="postgresql://click:click@localhost:5432/click_dev?schema=public"

# ─── Production (Neon) — replace in Vercel env vars ──────────────────────────
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── Google OAuth (console.cloud.google.com) ─────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Mapbox (account.mapbox.com) ─────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ─── App config ──────────────────────────────────────────────────────────────
FX_USD_HNL=24.70
ADMIN_EMAILS="admin@click.hn"
